rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - selectedLangs: list (required)
    //   - darkMode: bool (required)
    //   - updatedAt: timestamp (optional)
    //
    // Collection: users/{userId}/readLater
    // Document ID: {itemId} (usually base64 or hash of link)
    // Fields:
    //   - title: string (required)
    //   - link: string (required)
    //   - pubDate: string (required)
    //   - description: string (optional)
    //   - source: string (optional)
    //   - imageUrl: string (optional)
    //   - imageAlt: string (optional)
    //   - tags: list (optional)
    //   - savedAt: timestamp (optional)
    //
    // Collection: users/{userId}/searchHistory
    // Document ID: {queryId} (usually base64 or hash of query)
    // Fields:
    //   - query: string (required)
    //   - lastSearchTime: timestamp (required)
    //   - lastRecordTime: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "filben@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidUser(data) {
      return data.selectedLangs is list &&
             data.darkMode is bool &&
             data.selectedLangs.size() <= 20;
    }

    function isValidReadLater(data) {
      return data.title is string && data.title.size() < 500 &&
             data.link is string && data.link.size() < 1000 &&
             data.pubDate is string &&
             (!('description' in data) || (data.description is string && data.description.size() < 5000)) &&
             (!('tags' in data) || (data.tags is list && data.tags.size() < 20));
    }

    function isValidSearchHistory(data) {
      return data.query is string && data.query.size() < 200 &&
             data.lastSearchTime is timestamp &&
             data.lastRecordTime is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && hasOnlyAllowedFields(['selectedLangs', 'darkMode', 'updatedAt']);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && hasOnlyAllowedFields(['selectedLangs', 'darkMode', 'updatedAt']);
      
      match /readLater/{itemId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidReadLater(request.resource.data);
        allow update: if isOwner(userId) && isValidReadLater(request.resource.data);
        allow delete: if isOwner(userId) || isAdmin();
      }

      match /searchHistory/{queryId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidSearchHistory(request.resource.data);
        allow update: if isOwner(userId) && isValidSearchHistory(request.resource.data);
        allow delete: if isOwner(userId) || isAdmin();
      }
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
